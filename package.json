{
  "name": "@owlburtoe/pi-cc-tools",
  "version": "1.1.7",
  "description": "Claude Code-style tool rows for pi with Ctrl+O image previews and consistent built-in, MCP, and custom tool rendering",
  "keywords": [
    "pi-package",
    "pi-extension",
    "claude-code",
    "pi",
    "tool-renderer",
    "mcp",
    "terminal-images",
    "shiki",
    "diff"
  ],
  "license": "MIT",
  "author": "FammasMaz",
  "repository": {
    "type": "git",
    "url": "git+https://forgejo.owlburtoe.dev/owlburtoe/pi-claude-style-tools.git"
  },
  "homepage": "https://forgejo.owlburtoe.dev/owlburtoe/pi-claude-style-tools",
  "bugs": {
    "url": "https://forgejo.owlburtoe.dev/owlburtoe/pi-claude-style-tools/issues"
  },
  "files": [
    "README.md",
    "config/config.example.json",
    "extensions/index.ts",
    "extensions/inspection-summary.ts",
    "extensions/message-chrome.ts",
    "extensions/mutation-summary.ts",
    "extensions/spinner.ts"
  ],
  "scripts": {
    "bench:tools": "bun scripts/benchmark-tools.ts",
    "test:bash-display": "bun scripts/test-bash-display.ts",
    "test:message-chrome": "bun scripts/test-message-chrome.ts",
    "test:diff-body": "bun scripts/test-diff-body.ts",
    "test:inspection-summary": "bun scripts/test-inspection-summary.ts",
    "test:mutation-summary": "bun scripts/test-mutation-summary.ts",
    "test": "bun scripts/test-message-chrome.ts && bun scripts/test-bash-display.ts && bun scripts/test-inspection-summary.ts && bun scripts/test-mutation-summary.ts && bun scripts/test-diff-body.ts"
  },
  "dependencies": {
    "@shikijs/cli": "^4.0.2",
    "diff": "^7.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts",
      "./extensions/spinner.ts"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "@sinclair/typebox": "latest",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
